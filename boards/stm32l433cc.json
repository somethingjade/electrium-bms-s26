{
  "build": {
    "core": "stm32",
    "cpu": "cortex-m4",
    "extra_flags": "-DSTM32L4 -DSTM32L433xx",
    "f_cpu": "80000000L",
    "mcu": "stm32l433cc",
    "product_line": "STM32L433xx"
  },
  "debug": {
    "default_tools": [
      "stlink"
    ],
    "jlink_device": "STM32L433CC",
    "onboard_tools": [
      "stlink"
    ],
    "openocd_board": "st_nucleo_l4",
    "openocd_target": "stm32l4x",
    "svd_path": "STM32L4x3.svd"
  },
  "frameworks": [
    "arduino",
    "cmsis",
    "mbed",
    "stm32cube",
    "libopencm3",
    "zephyr"
  ],
  "name": "STM32L433CC",
  "upload": {
    "maximum_ram_size": 65536,
    "maximum_size": 262144,
    "protocol": "stlink",
    "protocols": [
      "jlink",
      "cmsis-dap",
      "stlink",
      "blackmagic",
      "mbed"
    ]
  },
  "url": "https://www.st.com/en/microcontrollers-microprocessors/stm32l433cc.html",
  "vendor": "Electrium"
}

